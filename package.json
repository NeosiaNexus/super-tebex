{
  "name": "@neosianexus/super-tebex",
  "version": "3.4.2",
  "description": "Tebex Headless SDK optimized for Next.js App Router with TanStack Query",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js",
      "require": "./dist/testing/index.cjs",
      "default": "./dist/testing/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "bun run build.ts --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --fix",
    "format": "prettier --write .",
    "clean": "bun run format && bun run lint",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "react": "^18.3.1 || ^19.0.0",
    "react-dom": "^18.3.1 || ^19.0.0",
    "next": "^14.0.0 || ^15.0.0",
    "@tanstack/react-query": "^5.0.0",
    "zustand": "^5.0.0",
    "tebex_headless": "^1.15.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.1",
    "@eslint/eslintrc": "^3.3.5",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.10",
    "@types/react": "^18.3.28",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-istanbul": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-no-floating-promise": "^2.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jsdom": "^29.0.0",
    "msw": "^2.12.11",
    "next": "^15.5.12",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "react": "^18.3.1",
    "react-dom": "^19.2.4",
    "tebex_headless": "^1.15.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "zustand": "^5.0.12"
  },
  "keywords": [
    "tebex",
    "nextjs",
    "react",
    "headless",
    "ecommerce",
    "minecraft",
    "game-server",
    "tanstack-query",
    "react-query"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NeosiaNexus/super-tebex.git"
  },
  "author": "NeosiaNexus <devneosianexus@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/NeosiaNexus/super-tebex#readme",
  "bugs": "https://github.com/NeosiaNexus/super-tebex/issues",
  "engines": {
    "node": ">=18"
  }
}
